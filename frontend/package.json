{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=moderate",
    "ci": "npm ci --ignore-scripts && npm run audit:prod && npm run check && npm run build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "1.4.0",
    "@tsconfig/svelte": "3.0.0",
    "autoprefixer": "10.4.20",
    "playwright": "1.61.1",
    "postcss": "8.5.16",
    "svelte": "3.59.2",
    "svelte-check": "2.10.3",
    "svelte-preprocess": "4.10.7",
    "tailwindcss": "3.4.17",
    "tslib": "2.8.1",
    "typescript": "4.9.5",
    "vite": "3.2.11"
  },
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
